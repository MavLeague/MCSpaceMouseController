{
  "schemaVersion": 1,
  "id": "spacemousecontroller",
  "version": "${version}",
  "name": "SpaceMouseController",
  "description": "A Minecraft Fabric Mod, which allows you to control the game using a 3dConnexion SpaceMouse.",
  "authors": ["MavLeague"],
  "contact": {
    "issues": "https://github.com/MavLeague/MCSpaceMouseController/issues",
    "homepage": "https://github.com/MavLeague/MCSpaceMouseController"
  },
  "license": "Apache License 2.0",
  "icon": "assets/spacemousecontroller/icon.png",
  "environment": "client",
  "entrypoints": {
    "fabric-datagen": [
      "org.mavleague.spacemousecontroller.client.SpacemousecontrollerDataGenerator"
    ],
    "client": [
      "org.mavleague.spacemousecontroller.client.SpacemousecontrollerClient"
    ],
    "main": [
      "org.mavleague.spacemousecontroller.Spacemousecontroller"
    ]
  },
  "mixins": [
    "spacemousecontroller.mixins.json",
    {
      "config": "spacemousecontroller.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
}
